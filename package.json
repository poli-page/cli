{
	"name": "@poli-page/cli",
	"version": "0.1.2",
	"description": "Poli Page CLI — scaffold projects, create templates, and render PDFs from the command line",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"bin": {
		"poli": "dist/index.js"
	},
	"files": [
		"dist",
		"templates",
		"README.md",
		"LICENSE"
	],
	"engines": {
		"node": ">=22.13.0"
	},
	"scripts": {
		"build": "tsc",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"dev": "tsx src/index.ts",
		"prepublishOnly": "pnpm run build"
	},
	"keywords": [
		"pdf",
		"cli",
		"poli-page",
		"pdf-generation",
		"html-to-pdf",
		"document",
		"templates",
		"reporting"
	],
	"author": "Poli Page",
	"license": "MIT",
	"homepage": "https://poli.page",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/poli-page/cli.git"
	},
	"bugs": {
		"url": "https://github.com/poli-page/cli/issues"
	},
	"publishConfig": {
		"access": "public"
	},
	"dependencies": {
		"@inquirer/prompts": "^8.4.2",
		"chalk": "^5.6.2",
		"commander": "^14.0.3",
		"open": "^11.0.0",
		"ora": "^9.4.0"
	},
	"devDependencies": {
		"@types/node": "^22.19.17",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vitest": "^4.1.5"
	}
}
